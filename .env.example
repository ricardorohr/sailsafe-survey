# SailSafe Survey — environment variables
# Copy this file to ".env" and paste your Google Apps Script Web App URL.
#
# How to get it: create a Google Sheet, open Extensions → Apps Script, paste
# google-apps-script/Code.gs, then Deploy → Web app. The URL ends with /exec.
# Full steps are at the top of google-apps-script/Code.gs and in the README.
#
# Without this, the form still runs for previewing but submissions aren't saved.

VITE_SHEETS_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXX/exec
